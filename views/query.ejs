<h2>检查记录查询</h2>

<div class="card">
  <h3>搜索</h3>
  <form method="GET" action="/query" class="inline-form">
    <label>日期</label>
    <input type="date" name="date" value="<%= date %>">
    <input type="text" name="q" placeholder="姓名/手机号/部门" value="<%= q %>">
    <button type="submit" class="btn btn-blue">查询</button>
  </form>
</div>

<div class="stats-grid">
  <div class="card stat-card">
    <div class="stat-num"><%= stats.total %></div>
    <div class="stat-label">总记录</div>
  </div>
  <div class="card stat-card green">
    <div class="stat-num"><%= stats.normal %></div>
    <div class="stat-label">正常</div>
  </div>
  <div class="card stat-card red">
    <div class="stat-num"><%= stats.warning %></div>
    <div class="stat-label">有隐患</div>
  </div>
</div>

<div class="card">
  <h3>记录列表（<%= date %>）</h3>
  <table>
    <thead><tr><th>类型</th><th>部门</th><th>职务</th><th>检查人</th><th>手机号</th><th>班次</th><th>结果</th></tr></thead>
    <tbody>
      <% if (records.length === 0) { %>
        <tr><td colspan="7" style="text-align:center;color:#888">暂无记录，请先同步数据</td></tr>
      <% } %>
      <% records.forEach(r => { %>
        <tr>
          <td><%= r.fixed_type %></td>
          <td><%= r.dept_name %></td>
          <td><%= r.job_name %></td>
          <td><%= r.create_user %></td>
          <td><%= r.phone %></td>
          <td><%= r.shift || '-' %></td>
          <td style="color:<%= r.check_result==='正常'?'green':'red'%>"><%= r.check_result %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
