<h2>查询记录</h2>
<div class="card">
  <form method="POST" action="/query/search" class="inline-form">
    <input type="text" name="keyword" placeholder="输入姓名或手机号" value="<%= keyword || '' %>" required>
    <select name="type">
      <option value="name" <%= searchType==='name'?'selected':'' %>>按姓名</option>
      <option value="phone" <%= searchType==='phone'?'selected':'' %>>按手机号</option>
    </select>
    <button type="submit" class="btn btn-blue">查询</button>
  </form>
</div>

<% if (error) { %>
<div class="card error"><%= error %></div>
<% } %>

<% if (results) { %>
<div class="card">
  <h3>查询结果（今日 <%= date %>）</h3>
  <% if (!results.rows || results.rows.length === 0) { %>
    <p class="hint">未找到记录</p>
  <% } else { %>
  <table>
    <thead>
      <tr>
        <% if (results.columns) { results.columns.forEach(col => { %><th><%= col %></th><% }) } %>
      </tr>
    </thead>
    <tbody>
      <% results.rows.forEach(row => { %>
      <tr>
        <% Object.values(row).forEach(val => { %><td><%= val || '-' %></td><% }) %>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>
<% } %>
