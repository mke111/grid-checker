<h2>人员管理</h2>

<div class="card">
  <h3>添加人员</h3>
  <form method="POST" action="/staff/add" class="inline-form">
    <input type="text" name="name" placeholder="姓名" required>
    <input type="text" name="phone" placeholder="手机号">
    <input type="text" name="department" placeholder="部门">
    <input type="text" name="position" placeholder="职务">
    <button type="submit" class="btn btn-green">添加</button>
  </form>
</div>

<div class="card">
  <h3>搜索</h3>
  <form method="GET" action="/staff" class="inline-form">
    <input type="text" name="q" placeholder="按姓名或手机号搜索" value="<%= q %>">
    <button type="submit" class="btn btn-blue">搜索</button>
    <a href="/staff" class="btn btn-gray">清除</a>
  </form>
</div>

<div class="card">
  <h3>批量操作</h3>
  <form method="POST" action="/staff/batch-status" class="inline-form">
    <input type="date" name="date" value="<%= date %>">
    <button type="submit" name="status" value="oncall" class="btn btn-green">全部设为在岗</button>
    <button type="submit" name="status" value="leave" class="btn btn-gray">全部设为休假</button>
  </form>
</div>

<div class="card">
  <h3>Excel 批量导入</h3>
  <form method="POST" action="/staff/import" enctype="multipart/form-data" class="inline-form">
    <input type="file" name="file" accept=".xlsx,.xls" required>
    <button type="submit" class="btn btn-blue">导入</button>
  </form>
  <p class="hint">Excel 需包含"姓名"和"手机号"列（可选：部门、职务）</p>
</div>

<div class="card">
  <h3>人员列表（<%= date %>）</h3>
  <table>
    <thead><tr><th>姓名</th><th>手机号</th><th>部门</th><th>职务</th><th>状态</th><th>操作</th></tr></thead>
    <tbody>
      <% if (staff.length === 0) { %>
        <tr><td colspan="6" style="text-align:center;color:#888">暂无人员，请添加或导入</td></tr>
      <% } %>
      <% staff.forEach(s => { %>
        <tr>
          <td><%= s.name %></td>
          <td><%= s.phone || '-' %></td>
          <td><%= s.department || '-' %></td>
          <td><%= s.position || '-' %></td>
          <td>
            <form method="POST" action="/staff/status" style="display:inline">
              <input type="hidden" name="staff_id" value="<%= s.id %>">
              <input type="hidden" name="date" value="<%= date %>">
              <% if (s.status === 'oncall') { %>
                <input type="hidden" name="status" value="leave">
                <button type="submit" class="btn btn-green btn-sm">在岗 ✓</button>
              <% } else { %>
                <input type="hidden" name="status" value="oncall">
                <button type="submit" class="btn btn-gray btn-sm">休假</button>
              <% } %>
            </form>
          </td>
          <td>
            <form method="POST" action="/staff/delete" style="display:inline" onsubmit="return confirm('确认删除？')">
              <input type="hidden" name="id" value="<%= s.id %>">
              <button type="submit" class="btn btn-red btn-sm">删除</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</div>
