<h2>系统设置</h2>

<div class="card">
  <h3>检查时间设置</h3>
  <form method="POST" action="/settings">
    <div class="form-group">
      <label>检查截止时间</label>
      <input type="time" name="check_end" value="<%= settings.check_end || '20:00' %>" class="form-control" style="width:200px">
      <p class="hint">超过此时间未填写的人员将显示为"逾期"</p>
    </div>
    <button type="submit" class="btn btn-primary">保存</button>
  </form>
</div>

<div class="card">
  <h3>通知设置</h3>
  <form method="POST" action="/settings">
    <div class="form-group">
      <label>自动通知时间</label>
      <input type="time" name="notify_time" value="<%= settings.notify_time || '20:00' %>" class="form-control" style="width:200px">
    </div>
    <div class="form-group">
      <label>Webhook 地址</label>
      <input type="text" name="notify_webhook" value="<%= settings.notify_webhook || '' %>" class="form-control" placeholder="https://...">
    </div>
    <button type="submit" class="btn btn-primary">保存</button>
  </form>
</div>
