<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>设置</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, sans-serif; background: #f5f7fa; }
    .header { background: #2d7a4f; color: white; padding: 16px 24px; display: flex; justify-content: space-between; }
    .header h1 { font-size: 20px; }
    .nav a { color: white; text-decoration: none; margin-left: 20px; }
    .container { max-width: 500px; margin: 24px auto; padding: 0 16px; }
    .card { background: white; border-radius: 12px; padding: 24px; margin-bottom: 16px; }
    h2, h3 { margin-bottom: 16px; }
    label { display: block; margin-bottom: 8px; font-weight: 500; }
    input { padding: 10px; border: 1px solid #ddd; border-radius: 6px; width: 100%; margin-bottom: 16px; }
    .btn { padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; background: #27ae60; color: white; }
    .hint { color: #666; font-size: 13px; }
  </style>
</head>
<body>
  <div class="header">
    <h1>📋 网格化检查系统</h1>
    <div class="nav">
      <a href="/">首页</a>
      <a href="/staff">人员管理</a>
      <a href="/accounts">账号管理</a>
      <a href="/settings">设置</a>
    </div>
  </div>
  
  <div class="container">
    <h2>系统设置</h2>
    
    <div class="card">
      <h3>检查时间</h3>
      <form method="POST" action="/settings">
        <label>截止时间（超过此时间未填写算逾期）</label>
        <input type="time" name="check_end" value="<%= checkEnd %>">
        
        <button type="submit" class="btn">保存</button>
      </form>
      <p class="hint">默认20:00</p>
    </div>
  </div>
</body>
</html>
