<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>账号管理</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: -apple-system, sans-serif; background: #f5f7fa; }
    .header { background: #2d7a4f; color: white; padding: 16px 24px; display: flex; justify-content: space-between; }
    .header h1 { font-size: 20px; }
    .nav a { color: white; text-decoration: none; margin-left: 20px; }
    .container { max-width: 600px; margin: 24px auto; padding: 0 16px; }
    .card { background: white; border-radius: 12px; padding: 24px; margin-bottom: 16px; }
    h2, h3 { margin-bottom: 16px; }
    input { padding: 10px; border: 1px solid #ddd; border-radius: 6px; width: 100%; margin-bottom: 12px; }
    .btn { padding: 10px 20px; border: none; border-radius: 6px; cursor: pointer; }
    .btn-green { background: #27ae60; color: white; }
    .btn-blue { background: #3498db; color: white; }
    .btn-red { background: #e74c3c; color: white; }
    table { width: 100%; border-collapse: collapse; }
    td { padding: 12px; border-bottom: 1px solid #eee; }
    .current { color: #27ae60; font-weight: 600; }
  </style>
</head>
<body>
  <div class="header">
    <h1>📋 网格化检查系统</h1>
    <div class="nav">
      <a href="/">首页</a>
      <a href="/staff">人员管理</a>
      <a href="/accounts">账号管理</a>
      <a href="/settings">设置</a>
    </div>
  </div>
  
  <div class="container">
    <h2>账号管理</h2>
    
    <div class="card">
      <h3>添加目标系统账号</h3>
      <form method="POST" action="/accounts/add">
        <input type="text" name="label" placeholder="名称（如：主账号）" required>
        <input type="text" name="base_url" placeholder="目标系统地址" value="http://221.181.9.210:17027" required>
        <input type="text" name="username" placeholder="用户名" required>
        <input type="password" name="password" placeholder="密码" required>
        <button type="submit" class="btn btn-green">添加</button>
      </form>
    </div>
    
    <div class="card">
      <h3>账号列表</h3>
      <table>
        <% accounts.forEach(a => { %>
          <tr>
            <td>
              <%= a.label %><br>
              <small style="color:#666"><%= a.username %></small>
            </td>
            <td>
              <% if (a.is_active) { %>
                <span class="current">✓ 当前使用</span>
              <% } %>
            </td>
            <td>
              <form method="POST" action="/accounts/activate" style="display:inline">
                <input type="hidden" name="id" value="<%= a.id %>">
                <button type="submit" class="btn btn-blue btn-sm"><%= a.is_active ? '使用中' : '切换' %></button>
              </form>
              <form method="POST" action="/accounts/delete" style="display:inline" onsubmit="return confirm('删除?')">
                <input type="hidden" name="id" value="<%= a.id %>">
                <button type="submit" class="btn btn-red btn-sm">删除</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </table>
    </div>
  </div>
</body>
</html>
