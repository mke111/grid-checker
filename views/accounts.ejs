<h2>账号管理</h2>
<div class="card">
  <h3>添加账号</h3>
  <form method="POST" action="/accounts/add" class="inline-form">
    <input type="text" name="label" placeholder="账号名称" required>
    <input type="text" name="username" placeholder="用户名" required>
    <input type="password" name="password" placeholder="密码" required>
    <button type="submit" class="btn btn-green">添加</button>
  </form>
</div>
<div class="card">
  <h3>账号列表</h3>
  <table>
    <thead><tr><th>名称</th><th>用户名</th><th>状态</th><th>操作</th></tr></thead>
    <tbody>
    <% accounts.forEach(a => { %>
      <tr>
        <td><%= a.label %></td>
        <td><%= a.username %></td>
        <td><%= a.is_active ? '✅ 当前使用' : '-' %></td>
        <td>
          <% if (!a.is_active) { %>
          <form method="POST" action="/accounts/activate" style="display:inline">
            <input type="hidden" name="id" value="<%= a.id %>">
            <button type="submit" class="btn btn-blue btn-sm">设为激活</button>
          </form>
          <% } %>
          <form method="POST" action="/accounts/delete" style="display:inline" onsubmit="return confirm('确认删除？')">
            <input type="hidden" name="id" value="<%= a.id %>">
            <button type="submit" class="btn btn-red btn-sm">删除</button>
          </form>
        </td>
      </tr>
    <% }) %>
    </tbody>
  </table>
</div>
